<header class="main-header sticky top-0 z-[100] bg-[#fdfdfd]/90 backdrop-blur-lg shadow-sm border-b border-gray-200">
  <nav class="navbar max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-20">
    <div class="logo">
      <a href="/" class="flex items-center space-x-2 group">
        <span class="text-2xl group-hover:-rotate-12 transition-transform duration-300">☕</span>
        <span class="font-black text-xl tracking-tighter text-gray-800 uppercase">FullStack <span class="text-gray-400">Cafe</span></span>
      </a>
    </div>

    <ul class="nav-links flex items-center space-x-6 text-[10px] font-black uppercase tracking-[0.2em] text-gray-500">
      <li><a href="/products" class="hover:text-gray-900 transition-all duration-300">Menu</a></li>

      <% if (locals.user) { %>
        <li class="hidden lg:block">
          <% if (user.role === 'admin') { %>
            <a href="/admin/dashboard" class="text-orange-600 hover:text-orange-700 font-black transition-colors flex items-center gap-1">
              <span class="text-sm">⚡</span> Admin Panel
            </a>
          <% } else { %>
            <a href="/orders/my-orders" class="hover:text-gray-900 transition-colors">My Orders</a>
          <% } %>
        </li>

        <li class="flex items-center space-x-2 bg-gray-50 px-3 py-1.5 rounded-full border border-gray-100 shadow-sm">
          <div class="avatar w-6 h-6 bg-slate-900 text-white rounded-full flex items-center justify-center text-[10px] font-black">
            <%= (user.name || user.username) ? (user.name || user.username).charAt(0).toUpperCase() : "U" %>
          </div>
          <span class="text-slate-700 lowercase font-bold tracking-tight">
            <%= (user.name || user.username || "User").split(' ')[0] %>
          </span>
        </li>
        
        <li>
          <a href="/logout" class="text-gray-300 hover:text-red-500 transition-colors duration-200">Logout</a>
        </li>

      <% } else { %>
        <li><a href="/login" class="hover:text-gray-900 transition-colors">Login</a></li>
        <li>
          <a href="/signup" class="bg-slate-900 text-white px-6 py-2.5 rounded-full hover:bg-slate-800 transition-all shadow-lg active:scale-95">
            Join Now
          </a>
        </li>
      <% } %>

      <li class="border-l border-gray-200 pl-4 hidden md:block">
        <a href="/support" class="hover:text-slate-900 transition-colors">
          <span class="font-bold text-slate-700">Support</span>
        </a>
      </li>

      <% if (!locals.user || user.role !== 'admin') { %>
      <li>
        <a href="/cart" class="relative flex items-center gap-1 group">
          <div class="relative">
            <svg class="w-6 h-6 text-slate-700 group-hover:text-slate-900 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
            <span id="cart-count-badge" 
              class="<%= (locals.cartCount && cartCount > 0) ? 'flex' : 'hidden' %> absolute -top-2 -right-2 bg-orange-600 text-white text-[9px] font-black w-5 h-5 items-center justify-center rounded-full border-2 border-white shadow-sm transition-all duration-300">
              <%= locals.cartCount || 0 %>
            </span>
          </div>
        </a>
      </li>
      <% } %>
    </ul>
  </nav>
</header>

<script>
/**
 * Updates the cart badge visibility and count in real-time.
 * Accessible globally for AJAX updates in product/cart pages.
 */
window.updateCartBadge = function(count) {
    const badge = document.getElementById('cart-count-badge');
    if (badge) {
        const numCount = parseInt(count) || 0;
        badge.innerText = numCount;
        
        if (numCount > 0) {
            badge.classList.remove('hidden');
            badge.classList.add('flex');
            // Pop animation
            badge.classList.add('scale-125');
            setTimeout(() => badge.classList.remove('scale-125'), 200);
        } else {
            badge.classList.add('hidden');
            badge.classList.remove('flex');
        }
    }
};

// Initial state check on page load
document.addEventListener('DOMContentLoaded', () => {
    const badge = document.getElementById('cart-count-badge');
    if (badge) {
        const currentCount = parseInt(badge.innerText.trim()) || 0;
        if (currentCount <= 0) {
            badge.classList.add('hidden');
            badge.classList.remove('flex');
        }
    }
});
</script>