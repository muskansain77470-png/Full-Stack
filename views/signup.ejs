<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Signup | FullStack Cafe</title>
  </head>
  <body class="bg-gray-50">
    <%- include('partials/header') %>

    <div class="flex items-center justify-center py-12 px-4">
      <div class="bg-white p-8 rounded-2xl shadow-lg w-full max-w-md border border-gray-100">
        <h2 class="text-3xl font-extrabold text-gray-800 mb-2 text-center">Join the Cafe</h2>
        <p class="text-gray-500 text-center mb-8">Create an account to start ordering food</p>

        <div id="msgBox" class="hidden mb-4 p-3 rounded-lg text-center border text-sm"></div>

        <form id="signupForm" class="space-y-5" enctype="multipart/form-data">
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">Full Name</label>
            <input type="text" name="username" id="username" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-500 focus:outline-none transition" placeholder="e.g. John Doe" required />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">Email Address</label>
            <input type="email" name="email" id="email" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-500 focus:outline-none transition" placeholder="e.g. john@gmail.com" required />
          </div>
          
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">Password</label>
            <input type="password" name="password" id="password" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-500 focus:outline-none transition" placeholder="Create a strong password" required />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">Profile Picture</label>
            <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-xl hover:border-red-400 transition cursor-pointer bg-gray-50 relative" onclick="document.getElementById('file-upload').click()">
              <div class="space-y-1 text-center">
                <svg class="mx-auto h-10 w-10 text-gray-400" id="upload-icon" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                  <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div class="flex text-sm text-gray-600 justify-center">
                  <span id="file-label" class="text-red-600 font-medium">Upload a file</span>
                  <input id="file-upload" name="profilePicture" type="file" class="hidden" accept="image/*" onchange="updateFileName()" />
                </div>
                <p class="text-xs text-gray-500">PNG, JPG up to 5MB</p>
              </div>
            </div>
          </div>

          <button type="submit" id="submitBtn" class="w-full bg-red-500 text-white py-3 rounded-xl font-bold text-lg hover:bg-red-600 shadow-lg transition duration-200 transform active:scale-[0.98]">
            Create Account
          </button>
        </form>

        <p class="mt-8 text-center text-sm text-gray-600">
          Already have an account? <a href="/login" class="text-gray-600 font-bold hover:underline">Login here</a>
        </p>
      </div>
    </div>

    <%- include('partials/footer') %>

    <script>
      function updateFileName() {
        const input = document.getElementById('file-upload');
        const label = document.getElementById('file-label');
        if (input.files && input.files[0]) {
          label.innerText = "Selected: " + input.files[0].name;
          label.classList.remove('text-red-600');
          label.classList.add('text-green-600');
        }
      }

      document.getElementById('signupForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        const msgBox = document.getElementById('msgBox');
        
        // UI Reset
        msgBox.classList.add('hidden');
        btn.disabled = true;
        btn.innerText = "Processing...";

        const formData = new FormData(e.target);

        try {
          const response = await fetch('/signup', {
            method: 'POST',
            body: formData
            // Note: Headers set mat karna, browser automatically boundary set kar dega FormData ke liye
          });

          // Check if response is JSON
          const contentType = response.headers.get("content-type");
          if (contentType && contentType.indexOf("application/json") !== -1) {
            const result = await response.json();

            if (result.success) {
              window.location.href = result.redirectUrl;
            } else {
              showError(result.message || "Registration failed.");
            }
          } else {
            // Agar server ne HTML bhej diya toh ye error handle karega
            showError("Server configuration error. Please try again.");
          }
        } catch (err) {
          console.error("Fetch Error:", err);
          showError("Connection lost. Check your internet.");
        } finally {
          btn.disabled = false;
          btn.innerText = "Create Account";
        }

        function showError(msg) {
          msgBox.innerText = msg;
          msgBox.className = "mb-4 p-3 rounded-lg text-center border bg-red-50 text-red-600 border-red-200";
          msgBox.classList.remove('hidden');
        }
      });
    </script>
  </body>
</html>