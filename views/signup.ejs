<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Signup | FullStack Cafe</title>
  </head>
  <body class="bg-gray-50">
    <%- include('partials/header') %>

    <div class="flex items-center justify-center py-12 px-4">
      <div class="bg-white p-8 rounded-2xl shadow-lg w-full max-w-md border border-gray-100">
        <h2 class="text-3xl font-extrabold text-gray-800 mb-2 text-center">Join the Cafe</h2>
        <p class="text-gray-500 text-center mb-8">Create an account to start ordering food</p>

        <div id="msgBox" class="hidden mb-4 p-3 rounded-lg text-center border text-sm"></div>

        <form id="signupForm" class="space-y-5">
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">Full Name</label>
            <input type="text" name="username" id="username" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-500 focus:outline-none transition" placeholder="e.g. name" required />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">Email Address</label>
            <input type="email" name="email" id="email" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-500 focus:outline-none transition" placeholder="e.g. name@gmail.com" required />
          </div>
          
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">Password</label>
            <input type="password" name="password" id="password" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-500 focus:outline-none transition" placeholder="Create a strong password" required />
          </div>

          <button type="submit" id="submitBtn" class="w-full bg-red-500 text-white py-3 rounded-xl font-bold text-lg hover:bg-red-600 shadow-lg transition duration-200 transform active:scale-[0.98]">
            Create Account
          </button>
        </form>

        <p class="mt-8 text-center text-sm text-gray-600">
          Already have an account? <a href="/login" class="text-gray-600 font-bold hover:underline">Login here</a>
        </p>
      </div>
    </div>

    <%- include('partials/footer') %>

    <script>
      function displayMessage(msg, isError = true) {
        const msgBox = document.getElementById('msgBox');
        msgBox.innerText = msg;
        msgBox.className = isError 
          ? "mb-4 p-3 rounded-lg text-center border bg-red-50 text-red-600 border-red-200" 
          : "mb-4 p-3 rounded-lg text-center border bg-green-50 text-green-600 border-green-200";
        msgBox.classList.remove('hidden');
      }

      document.getElementById('signupForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        const msgBox = document.getElementById('msgBox');
        
        msgBox.classList.add('hidden');
        btn.disabled = true;
        btn.innerText = "Processing...";

        // Converting form data to a regular JSON object since we are no longer uploading files
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());

        try {
          const response = await fetch('/signup', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
          });

          const result = await response.json();

          if (result.success) {
            window.location.href = result.redirectUrl;
          } else {
            displayMessage(result.message || "Registration failed.");
          }
        } catch (err) {
          console.error("Fetch Error:", err);
          displayMessage("Connection lost. Check your internet.");
        } finally {
          btn.disabled = false;
          btn.innerText = "Create Account";
        }
      });
    </script>
  </body>
</html>