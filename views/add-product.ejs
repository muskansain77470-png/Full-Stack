<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Item | FullStack Cafe</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #f8fafc; font-family: 'Inter', sans-serif; }
        .glass-card { background: white; border: 1px solid #e2e8f0; }
        #toast {
            visibility: hidden;
            min-width: 250px;
            background-color: #1e293b;
            color: white;
            text-align: center;
            border-radius: 12px;
            padding: 16px;
            position: fixed;
            left: 50%;
            bottom: 30px;
            transform: translateX(-50%);
            z-index: 100;
        }
        #toast.show { visibility: visible; animation: fadein 0.5s, fadeout 0.5s 2.5s; }
        @keyframes fadein { from { bottom: 0; opacity: 0; } to { bottom: 30px; opacity: 1; } }
        @keyframes fadeout { from { bottom: 30px; opacity: 1; } to { bottom: 0; opacity: 0; } }
    </style>
</head>
<body>
    <%- include('partials/header') %>

    <main class="max-w-2xl mx-auto px-4 py-12">
        <div class="glass-card p-8 md:p-12 rounded-[2.5rem] shadow-xl">
            <h1 class="text-3xl font-black mb-8">Add New Product ☕</h1>

            <form id="productForm" action="/admin/products/add" method="POST" enctype="multipart/form-data" class="space-y-6">
                
                <div>
                    <label class="block text-xs font-bold uppercase text-gray-400 mb-2">Product Name</label>
                    <input type="text" name="name" required class="w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl" placeholder="Mocha Frappe">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold uppercase text-gray-400 mb-2">Category</label>
                        <select name="category" required class="w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl">
                            <option value="Drink">Drink</option>
                            <option value="Junk">Junk</option>
                            <option value="Desert">Desert</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase text-gray-400 mb-2">Price (INR)</label>
                        <input type="number" name="price" required class="w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl" placeholder="250">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase text-gray-400 mb-2">Initial Stock</label>
                    <input type="number" name="stock" required class="w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl" placeholder="10">
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase text-gray-400 mb-2">Product Image</label>
                    <input type="file" name="image" accept="image/*" required class="w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl border-dashed border-2">
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase text-gray-400 mb-2">Description</label>
                    <textarea name="description" rows="3" required class="w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl" placeholder="Briefly describe the item..."></textarea>
                </div>

                <button type="submit" class="w-full py-5 bg-slate-900 text-white font-black uppercase rounded-2xl hover:bg-slate-800 transition-all">
                    Upload & Save Product
                </button>
            </form>
        </div>
    </main>

    <div id="toast">✅ Product Added Successfully!</div>

    <script>
        const form = document.getElementById('productForm');
        form.addEventListener('submit', () => {
            document.getElementById("toast").className = "show";
            // Note: Form will naturally redirect after submission
        });
    </script>
</body>
</html>