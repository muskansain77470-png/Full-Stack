<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .status-Pending { background-color: #fff7ed; color: #c2410c; }
        .status-Preparing { background-color: #f0f9ff; color: #0369a1; }
        .status-Ready { background-color: #f5f3ff; color: #6d28d9; }
        .status-Delivered { background-color: #f0fdf4; color: #15803d; }
        .status-Cancelled { background-color: #fef2f2; color: #b91c1c; }
        .step-node { transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
    </style>
</head>
<body class="bg-[#f8fafc] text-gray-900 font-sans antialiased">
    <%- include('./partials/header') %> 
    
    <div id="notification-container" class="fixed top-24 right-6 z-50 space-y-4"></div>

    <main class="max-w-5xl mx-auto px-4 py-16">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
            <div>
                <h1 class="text-6xl font-black tracking-tighter text-slate-900 italic uppercase">
                    My <span class="text-orange-500 not-italic">Orders</span>
                </h1>
                <p class="text-slate-400 font-medium mt-2">Track your caffeine and snacks history in real-time.</p>
            </div>
            <a href="/products" class="inline-flex items-center gap-2 bg-white border-2 border-slate-100 px-6 py-3 rounded-2xl text-sm font-black uppercase tracking-widest text-slate-600 hover:text-orange-600 hover:border-orange-100 transition-all shadow-sm">
                <i class="fas fa-plus text-xs"></i> New Order
            </a>
        </div>

        <% if (orders && orders.length > 0) { %>
            <div class="space-y-10" id="orders-list">
                <% orders.forEach(order => { %>
                    <div class="bg-white rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-50 overflow-hidden group transition-all hover:-translate-y-1 order-container" data-id="<%= order._id %>">
                        
                        <div class="bg-slate-50/50 px-8 py-5 border-b border-slate-100 flex flex-wrap justify-between items-center gap-4">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center shadow-sm border border-slate-100">
                                    <i class="fas fa-hashtag text-slate-300 text-xs"></i>
                                </div>
                                <div>
                                    <p class="text-[9px] font-bold text-slate-400 uppercase tracking-[0.2em]">Transaction ID</p>
                                    <p class="text-xs font-mono font-bold text-slate-600 cursor-pointer hover:text-orange-500" onclick="navigator.clipboard.writeText('<%= order._id %>'); showToast('ID Copied!')">
                                        <%= order._id %>
                                    </p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-[0.2em]">Placed On</p>
                                <p class="text-sm font-black text-slate-800 tracking-tight"><%= order.displayDate %></p>
                            </div>
                        </div>

                        <div class="p-8 md:p-10">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
                                <div>
                                    <h3 class="text-[10px] font-black text-orange-500 uppercase tracking-[0.3em] mb-6">Menu Items</h3>
                                    <ul class="space-y-4">
                                        <% order.items.forEach(item => { %>
                                            <li class="flex items-center group/item">
                                                <span class="w-8 h-8 flex items-center justify-center bg-slate-100 text-slate-500 rounded-lg text-[10px] font-black mr-4 group-hover/item:bg-orange-500 group-hover/item:text-white transition-colors uppercase">
                                                    x<%= item.quantity %>
                                                </span>
                                                <span class="font-bold <%= item.productId ? 'text-slate-700' : 'text-slate-400 italic' %> tracking-tight">
                                                    <%= item.productId ? item.productId.name : 'Item no longer available' %>
                                                </span>
                                            </li>
                                        <% }) %>
                                    </ul>
                                </div>

                                <div class="bg-slate-50 rounded-[2rem] p-8 border border-slate-100 text-center md:text-right">
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.3em] mb-2">Total Amount</p>
                                    <p class="text-5xl font-black text-slate-900 tracking-tighter mb-4">₹<%= order.totalAmount %></p>
                                    
                                    <span id="status-badge-<%= order._id %>" class="inline-block px-5 py-2 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm status-<%= order.status %>">
                                        <i class="fas fa-circle text-[6px] mr-2 opacity-50"></i>
                                        <span id="status-text-<%= order._id %>"><%= order.status %></span>
                                    </span>
                                </div>
                            </div>

                            <div class="mt-12 px-2 <%= order.status === 'Cancelled' ? 'hidden' : '' %>" id="tracking-container-<%= order._id %>">
                                <% 
                                    const statusMap = { 'Pending': 10, 'Preparing': 40, 'Ready': 75, 'Delivered': 100 };
                                    const progressWidth = statusMap[order.status] || 0;
                                %>
                                <div class="relative h-3 bg-slate-100 rounded-full overflow-hidden mb-6 border border-slate-50">
                                    <div id="progress-bar-<%= order._id %>" 
                                         class="absolute h-full bg-orange-500 transition-all duration-1000 ease-out rounded-full shadow-[0_0_15px_rgba(249,115,22,0.4)]" 
                                         style="width: <%= progressWidth %>%">
                                    </div>
                                </div>
                                <div class="flex justify-between items-start">
                                    <% const steps = [
                                        { key: 'Pending', icon: 'fa-clock', label: 'Ordered' },
                                        { key: 'Preparing', icon: 'fa-fire-alt', label: 'Kitchen' },
                                        { key: 'Ready', icon: 'fa-box-open', label: 'Ready' },
                                        { key: 'Delivered', icon: 'fa-heart', label: 'Enjoy' }
                                    ]; %>
                                    <% steps.forEach((step) => { 
                                        const isDone = statusMap[order.status] >= statusMap[step.key];
                                        const isCurrent = order.status === step.key;
                                    %>
                                        <div class="flex flex-col items-center w-1/4">
                                            <div id="step-<%= order._id %>-<%= step.key %>" 
                                                 class="step-node w-10 h-10 rounded-2xl flex items-center justify-center text-xs 
                                                 <%= isDone ? 'bg-orange-500 text-white shadow-lg shadow-orange-200' : 'bg-white text-slate-300 border border-slate-100' %> 
                                                 <%= isCurrent ? 'ring-4 ring-orange-100 scale-110' : '' %>">
                                                <i class="fas <%= step.icon %>"></i>
                                            </div>
                                            <span class="step-label text-[9px] font-black uppercase mt-3 tracking-tighter <%= isDone ? 'text-slate-800' : 'text-slate-300' %> text-center">
                                                <%= step.label %>
                                            </span>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                        </div>

                        <div class="px-8 py-6 bg-slate-50/30 border-t border-slate-50 flex flex-wrap justify-end gap-4">
                            <% if (order.status === 'Pending') { %>
                                <button id="cancel-btn-<%= order._id %>" onclick="cancelOrder(this, '<%= order._id %>')" 
                                        class="px-8 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest text-red-500 bg-white border border-red-50 hover:bg-red-500 hover:text-white transition-all shadow-sm">
                                    Cancel Order
                                </button>
                            <% } %>
                            <button onclick="reorderItems(this, '<%= order._id %>')" 
                                    class="px-10 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest bg-slate-900 text-white hover:bg-orange-600 transition-all shadow-lg flex items-center gap-3">
                                <i class="fas fa-redo-alt text-[10px]"></i> Reorder
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>

            <div class="flex flex-col md:flex-row justify-between items-center mt-16 gap-6">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">
                    Page <%= currentPage %> <span class="mx-2 opacity-30">/</span> <%= totalPages %>
                </p>
                <div class="flex gap-3">
                    <% if (hasPreviousPage) { %>
                        <a href="/orders/my-orders?page=<%= previousPage %>" class="w-14 h-14 bg-white border border-slate-100 flex items-center justify-center rounded-2xl text-slate-600 hover:text-orange-500 hover:border-orange-100 shadow-sm transition-all">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    <% } %>
                    <% if (hasNextPage) { %>
                        <a href="/orders/my-orders?page=<%= nextPage %>" class="w-14 h-14 bg-white border border-slate-100 flex items-center justify-center rounded-2xl text-slate-600 hover:text-orange-500 hover:border-orange-100 shadow-sm transition-all">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } %>
                </div>
            </div>
        <% } else { %>
            <div class="text-center py-32 bg-white rounded-[4rem] border-4 border-dashed border-slate-100">
                <div class="text-9xl mb-10 opacity-20 grayscale">📄</div>
                <h2 class="text-4xl font-black text-slate-800 tracking-tight uppercase italic">No Orders Yet</h2>
                <a href="/products" class="mt-8 px-14 py-5 bg-slate-900 text-white font-black rounded-3xl hover:shadow-xl transition-all inline-block uppercase tracking-[0.2em] text-xs">Start Ordering</a>
            </div>
        <% } %>
    </main>

    <%- include('./partials/footer') %> 

    <script>
        const socket = io();

        // 1. Join Private Room for each order to ensure updates are received
        document.querySelectorAll('.order-container').forEach(container => {
            const orderId = container.getAttribute('data-id');
            socket.emit('join', `order_${orderId}`);
        });

        // 2. Listen for Status Changes
        socket.on('orderStatusChanged', (data) => {
            console.log("Status Update Received:", data);
            const { orderId, status } = data;
            const statusMap = { 'Pending': 10, 'Preparing': 40, 'Ready': 75, 'Delivered': 100 };
            
            const badge = document.getElementById(`status-badge-${orderId}`);
            const text = document.getElementById(`status-text-${orderId}`);
            const bar = document.getElementById(`progress-bar-${orderId}`);
            const cancelBtn = document.getElementById(`cancel-btn-${orderId}`);

            if (text) text.innerText = status;
            if (badge) {
                badge.className = `inline-block px-5 py-2 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm status-${status}`;
            }
            if (bar) bar.style.width = statusMap[status] + '%';

            // Update Steps Icons
            const steps = ['Pending', 'Preparing', 'Ready', 'Delivered'];
            steps.forEach(stepKey => {
                const node = document.getElementById(`step-${orderId}-${stepKey}`);
                if (node) {
                    const isDone = statusMap[status] >= statusMap[stepKey];
                    const isCurrent = status === stepKey;
                    
                    node.className = `step-node w-10 h-10 rounded-2xl flex items-center justify-center text-xs transition-all duration-500 ${isDone ? 'bg-orange-500 text-white shadow-lg shadow-orange-200' : 'bg-white text-slate-300 border border-slate-100'} ${isCurrent ? 'ring-4 ring-orange-100 scale-110' : ''}`;
                }
            });

            if (status !== 'Pending' && cancelBtn) cancelBtn.classList.add('hidden');
            if (status === 'Cancelled') document.getElementById(`tracking-container-${orderId}`)?.classList.add('hidden');

            showToast(`Order Status: ${status}`);
        });

        // Toast Helper
        function showToast(msg, isError = false) {
            const container = document.getElementById('notification-container');
            const toast = document.createElement('div');
            toast.className = `${isError ? 'bg-red-600' : 'bg-slate-900'} text-white px-8 py-4 rounded-2xl shadow-2xl flex items-center gap-4 transform transition-all duration-500 translate-x-full opacity-0`;
            toast.innerHTML = `<i class="fas ${isError ? 'fa-exclamation-triangle' : 'fa-bell'} text-xs"></i><span class="text-xs font-black uppercase tracking-widest">${msg}</span>`;
            container.appendChild(toast);
            setTimeout(() => toast.classList.remove('translate-x-full', 'opacity-0'), 10);
            setTimeout(() => {
                toast.classList.add('translate-x-full', 'opacity-0');
                setTimeout(() => toast.remove(), 500);
            }, 4000);
        }

        // Cancel Logic
        async function cancelOrder(btn, orderId) {
            const result = await Swal.fire({
                title: 'Are you sure?',
                text: "Order will be cancelled and stock returned.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'Yes, Cancel'
            });

            if (result.isConfirmed) {
                btn.disabled = true;
                try {
                    const res = await fetch(`/orders/cancel/${orderId}`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        showToast("Order Cancelled");
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast(data.message, true);
                        btn.disabled = false;
                    }
                } catch (e) { 
                    showToast("Network Error", true);
                    btn.disabled = false;
                }
            }
        }

        // Reorder Logic
        async function reorderItems(btn, orderId) {
            btn.disabled = true;
            try {
                const res = await fetch(`/orders/reorder/${orderId}`, { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    showToast("Added to cart!");
                    setTimeout(() => window.location.href = '/cart', 1000);
                } else {
                    showToast(data.message, true);
                    btn.disabled = false;
                }
            } catch (e) {
                showToast("Network Error", true);
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>