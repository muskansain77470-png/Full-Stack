<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders | FullStack Cafe</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-900 font-sans">
    <%- include('partials/header') %>

    <main class="max-w-4xl mx-auto px-4 py-12">
        <h1 class="text-3xl font-black mb-8">My Orders</h1>

        <% if (orders && orders.length > 0) { %>
            <div class="space-y-6">
                <% orders.forEach(order => { %>
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <div class="flex justify-between items-center mb-4">
                            <div>
                                <p class="text-sm text-gray-500">Order ID: #<%= order._id %></p>
                                <p class="text-sm text-gray-500">Date: <%= order.displayDate %></p>
                            </div>
                            <span class="px-4 py-1 rounded-full text-xs font-bold uppercase <%= order.statusClass %>">
                                <%= order.status %>
                            </span>
                        </div>
                        <div class="border-t pt-4">
                            <p class="text-lg font-bold">Total Amount: ₹<%= order.totalAmount %></p>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-20 bg-white rounded-3xl border-2 border-dashed border-gray-200">
                <p class="text-gray-500">No orders found. ☕ Go get some coffee!</p>
            </div>
        <% } %>
    </main>
    <%- include('partials/footer') %>
</body>
</html>