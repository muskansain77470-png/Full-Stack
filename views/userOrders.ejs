<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders | FullStack Cafe</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-900 font-sans">
    <%- include('./partials/header') %> <div id="notification-container" class="fixed top-20 right-5 z-50 space-y-3"></div>

    <main class="max-w-4xl mx-auto px-4 py-12">
        <div class="flex items-center justify-between mb-8">
            <h1 class="text-4xl font-black tracking-tight">My Orders</h1>
            <a href="/products" class="text-orange-600 font-bold hover:underline">
                <i class="fas fa-plus mr-1"></i> New Order
            </a>
        </div>

        <% if (orders && orders.length > 0) { %>
            <div class="space-y-8">
                <% orders.forEach(order => { %>
                    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
                        <div class="bg-gray-50 px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                            <div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Order ID</p>
                                <p class="text-sm font-mono text-gray-600">#<%= order._id %></p>
                            </div>
                            <div class="text-right">
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Ordered On</p>
                                <p class="text-sm font-semibold text-gray-700"><%= order.displayDate %></p>
                            </div>
                        </div>

                        <div class="p-6">
                            <div class="flex flex-col md:flex-row md:items-start justify-between gap-6 mb-8">
                                <div>
                                    <h3 class="text-xs font-bold text-gray-400 uppercase mb-3">Items</h3>
                                    <ul class="space-y-2">
                                        <% order.items.forEach(item => { %>
                                            <li class="flex items-center text-sm">
                                                <span class="bg-orange-100 text-orange-700 px-2 py-0.5 rounded-md text-xs font-bold mr-2">x<%= item.quantity %></span>
                                                <span class="font-medium text-gray-700"><%= item.productId ? item.productId.name : 'Unknown Product' %></span>
                                            </li>
                                        <% }) %>
                                    </ul>
                                </div>
                                <div class="text-right">
                                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Total Paid</p>
                                    <p class="text-3xl font-black text-gray-900">₹<%= order.totalAmount %></p>
                                    <span class="inline-block mt-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= order.statusClass %>">
                                        <%= order.status %>
                                    </span>
                                </div>
                            </div>

                            <% if (order.status !== 'Cancelled') { %>
                            <div class="relative px-2 py-4">
                                <% 
                                    const statusMap = { 'Pending': 10, 'Preparing': 37, 'Ready': 65, 'Delivered': 100 };
                                    const progressWidth = statusMap[order.status] || 0;
                                %>
                                <div class="relative h-2 bg-gray-100 rounded-full overflow-hidden mb-2">
                                    <div class="absolute h-full bg-orange-500 transition-all duration-700 rounded-full" style="width: <%= progressWidth %>%"></div>
                                </div>
                                <div class="flex justify-between mt-4">
                                    <% const steps = [
                                        { key: 'Pending', icon: 'fa-clock', label: 'Pending' },
                                        { key: 'Preparing', icon: 'fa-utensils', label: 'Preparing' },
                                        { key: 'Ready', icon: 'fa-truck', label: 'Ready' },
                                        { key: 'Delivered', icon: 'fa-check-double', label: 'Delivered' }
                                    ]; %>
                                    <% steps.forEach((step) => { 
                                        const isCurrent = order.status === step.key;
                                    %>
                                        <div class="flex flex-col items-center">
                                            <div class="w-8 h-8 rounded-full flex items-center justify-center text-[10px] shadow-sm <%= isCurrent ? 'bg-orange-500 text-white ring-4 ring-orange-100' : 'bg-gray-50 text-gray-300 border' %>">
                                                <i class="fas <%= step.icon %>"></i>
                                            </div>
                                            <span class="text-[9px] font-black uppercase mt-2 <%= isCurrent ? 'text-orange-600' : 'text-gray-400' %>"><%= step.label %></span>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                            <% } %>
                        </div>

                        <div class="px-6 py-4 border-t border-gray-50 bg-white flex justify-end gap-3">
                            <% if (order.status === 'Pending') { %>
                                <button onclick="cancelOrder(event, '<%= order._id %>')" 
                                        class="bg-red-50 text-red-600 px-6 py-2.5 rounded-2xl text-sm font-bold hover:bg-red-100 transition-all">
                                    Cancel Order
                                </button>
                            <% } %>
                            
                            <button onclick="reorderItems(event, '<%= order._id %>')" 
                                    class="bg-slate-900 text-white px-6 py-2.5 rounded-2xl text-sm font-bold hover:bg-black transition-all flex items-center gap-2">
                                <i class="fas fa-redo-alt text-xs"></i>
                                <span>Reorder</span>
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-20 bg-white rounded-3xl border border-dashed border-gray-200">
                <i class="fas fa-receipt text-5xl text-gray-200 mb-4"></i>
                <p class="text-gray-500 font-medium">No orders found yet.</p>
                <a href="/products" class="text-orange-600 font-bold mt-2 inline-block">Order something delicious!</a>
            </div>
        <% } %>
    </main>

    <%- include('./partials/footer') %> <script>
        // 1. Cancel Order Logic
        async function cancelOrder(event, orderId) {
            if (!confirm("Are you sure you want to cancel this order?")) return;

            const btn = event.currentTarget;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Cancelling...';

            try {
                const response = await fetch(`/orders/cancel/${orderId}`, { method: 'POST' });
                const data = await response.json();
                
                if (data.success) {
                    showNotification(data.message);
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showNotification(data.message, true);
                    btn.disabled = false;
                    btn.innerHTML = 'Cancel Order';
                }
            } catch (err) {
                showNotification("Error connecting to server", true);
                btn.disabled = false;
            }
        }

        // 2. Reorder Logic (FIXED URL)
        async function reorderItems(event, orderId) {
            const btn = event.currentTarget;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Restoring...';

            try {
                // CHANGED: Matches router.post("/reorder/:id", ...)
                const response = await fetch(`/orders/reorder/${orderId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();
                if (data.success) {
                    showNotification(data.message);
                    // Stay on this page to show the new order, or go to cart if you prefer
                    setTimeout(() => location.reload(), 1200);
                } else {
                    showNotification(data.message || "Failed to reorder", true);
                    btn.disabled = false;
                    btn.innerHTML = 'Reorder';
                }
            } catch (err) {
                showNotification("Server communication error", true);
                btn.disabled = false;
                btn.innerHTML = 'Reorder';
            }
        }

        // 3. Notification UI
        function showNotification(msg, isError = false) {
            const container = document.getElementById('notification-container');
            const toast = document.createElement('div');
            toast.className = `${isError ? 'bg-red-600' : 'bg-slate-900'} text-white px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-3 transform transition-all duration-300 translate-x-full opacity-0`;
            toast.innerHTML = `<i class="fas ${isError ? 'fa-exclamation-circle' : 'fa-check-circle'}"></i><span class="text-sm font-bold">${msg}</span>`;
            
            container.appendChild(toast);
            
            // Trigger animation
            setTimeout(() => {
                toast.classList.remove('translate-x-full', 'opacity-0');
            }, 10);

            // Remove after 3 seconds
            setTimeout(() => {
                toast.classList.add('translate-x-full', 'opacity-0');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
    </script>
</body>
</html>