<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Forgot Password | FullStack Café</title>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen p-6">
    <div class="bg-white p-10 rounded-[2.5rem] shadow-xl border border-slate-100 max-w-md w-full">
        <h1 class="text-3xl font-black tracking-tighter text-slate-800 uppercase mb-2">Reset Password</h1>
        <p class="text-slate-500 mb-8 text-sm">Enter your email and we'll send you a code to reset your password.</p>

        <div id="responseMessage" class="hidden text-xs font-bold mb-4 uppercase"></div>

        <form id="forgotPasswordForm" class="space-y-6">
            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-2">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="name@email.com"
                    class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-6 py-4 outline-none focus:ring-2 focus:ring-slate-900">
            </div>
            <button type="submit" id="submitBtn" class="w-full bg-slate-900 text-white py-4 rounded-2xl font-bold hover:bg-slate-800 transition-all shadow-lg flex items-center justify-center">
                <span>Send Reset Code</span>
            </button>
        </form>

        <div class="mt-6 text-center">
            <a href="/login" class="text-xs font-bold text-slate-400 hover:text-slate-900 uppercase">Back to Login</a>
        </div>
    </div>

    <script>
        const form = document.getElementById('forgotPasswordForm');
        const btn = document.getElementById('submitBtn');
        const msgDiv = document.getElementById('responseMessage');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            // 1. Loading State
            btn.disabled = true;
            btn.innerHTML = 'Sending...';
            msgDiv.classList.add('hidden');

            const email = document.getElementById('email').value;

            try {
                // 2. Fetch Request
                const response = await fetch('/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });

                // If the controller uses res.render, fetch will get the HTML. 
                // To make this work best, ensure your controller returns JSON or check redirect.
                if (response.redirected) {
                    window.location.href = response.url;
                    return;
                }

                // If the controller renders the page again with an error
                const result = await response.text(); 
                
                // If the response is a redirect to verify-otp, handle it:
                if (response.ok) {
                    // Logic to handle success (e.g., if you return JSON)
                    // If your backend redirects, fetch follows it automatically.
                    document.documentElement.innerHTML = result;
                } else {
                    msgDiv.textContent = "Error sending email. Try again.";
                    msgDiv.className = "text-red-500 text-xs font-bold mb-4 uppercase block";
                    btn.disabled = false;
                    btn.innerHTML = 'Send Reset Code';
                }

            } catch (error) {
                msgDiv.textContent = "Network error. Please check your connection.";
                msgDiv.className = "text-red-500 text-xs font-bold mb-4 uppercase block";
                btn.disabled = false;
                btn.innerHTML = 'Send Reset Code';
            }
        });
    </script>
</body>
</html>