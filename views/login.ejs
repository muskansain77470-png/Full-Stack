<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Login | FullStack Café</title>
  </head>
  <body class="bg-gray-50">
    <%- include('partials/header') %>

    <div class="flex items-center justify-center py-20 px-4">
      <div class="bg-white p-8 rounded-2xl shadow-lg w-full max-w-md border border-gray-100">
        <h2 class="text-3xl font-extrabold text-gray-800 mb-2 text-center uppercase tracking-tighter">
          Welcome to Login
        </h2>
        <p class="text-gray-500 text-center mb-8 text-sm">
          Login to order your food or manage the cafe.
        </p>

        <div id="errorContainer" class="<%= locals.message ? '' : 'hidden' %> mb-4 p-3 bg-red-50 border border-red-200 text-red-600 text-xs rounded-xl text-center font-bold uppercase tracking-tight">
          <span id="errorMessage"><%= locals.message %></span>
        </div>

        <form id="loginForm" class="space-y-5">
          <div>
            <label class="block text-[10px] font-black text-gray-400 uppercase mb-1 tracking-widest px-2">Email Address</label>
            <input
              type="email" 
              name="email"
              id="email"
              autocomplete="email"
              class="w-full bg-slate-50 border border-gray-200 rounded-2xl px-6 py-4 outline-none focus:ring-4 focus:ring-gray-900/5 focus:border-gray-800 transition-all"
              placeholder="Enter your registered email"
              required
            />
          </div>

          <div>
            <label class="block text-[10px] font-black text-gray-400 uppercase mb-1 tracking-widest px-2">Password</label>
            <input
              type="password"
              name="password"
              id="password"
              autocomplete="current-password"
              class="w-full bg-slate-50 border border-gray-200 rounded-2xl px-6 py-4 outline-none focus:ring-4 focus:ring-gray-900/5 focus:border-gray-800 transition-all"
              placeholder="••••••••"
              required
            />
          </div>

          <div class="flex items-center justify-between text-xs px-2">
            <label class="flex items-center text-gray-500 cursor-pointer font-bold uppercase tracking-tighter">
              <input type="checkbox" class="mr-2 rounded text-gray-800 focus:ring-gray-800" />
              Remember me
            </label>
            <a href="/forgot-password" class="text-gray-400 hover:text-gray-800 font-bold uppercase tracking-tighter transition">
              Forgot Password?
            </a>
          </div>

          <button
            type="submit"
            id="loginBtn"
            class="w-full bg-gray-800 text-white py-5 rounded-2xl font-bold text-lg hover:bg-black shadow-xl transition-all active:scale-[0.96] disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="btnText">Login Now</span>
          </button>
        </form>

        <p class="mt-8 text-center text-xs font-bold text-gray-400 uppercase tracking-widest">
          New here?
          <a href="/signup" class="text-red-600 hover:underline ml-1">Signup Now</a>
        </p>
      </div>
    </div>

    <%- include('partials/footer') %>

    <script>
      const loginForm = document.getElementById('loginForm');
      const loginBtn = document.getElementById('loginBtn');
      const btnText = document.getElementById('btnText');
      const errorContainer = document.getElementById('errorContainer');
      const errorMessage = document.getElementById('errorMessage');

      loginForm.addEventListener('submit', async (e) => {
        e.preventDefault(); 

        // Reset UI state
        loginBtn.disabled = true;
        btnText.innerText = "Authenticating...";
        errorContainer.classList.add('hidden');

        // UPDATED: Sending 'email' instead of 'username'
        const payload = {
          email: document.getElementById('email').value.trim().toLowerCase(),
          password: document.getElementById('password').value
        };

        try {
          const response = await fetch('/login', {
            method: 'POST',
            headers: { 
              'Content-Type': 'application/json',
              'Accept': 'application/json' 
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (response.ok && result.success) {
            window.location.href = result.redirectUrl;
          } else {
            throw new Error(result.message || "Invalid Login Credentials");
          }

        } catch (err) {
          errorMessage.innerText = err.message || "Network Error. Please check your server.";
          errorContainer.classList.remove('hidden');
          
          loginBtn.disabled = false;
          btnText.innerText = "Login Now";
        }
      });
    </script>
  </body>
</html>