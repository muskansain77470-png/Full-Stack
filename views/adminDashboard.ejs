<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <title>Command Center | Full Stack Café</title>
    <style>
        .status-badge { transition: all 0.3s ease; }
        .tab-content { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .status-Pending { background-color: #fffbeb !important; color: #d97706 !important; border: 1px solid #fde68a !important; }
        .status-Preparing { background-color: #eff6ff !important; color: #2563eb !important; border: 1px solid #bfdbfe !important; }
        .status-Ready { background-color: #faf5ff !important; color: #9333ea !important; border: 1px solid #e9d5ff !important; }
        .status-Delivered { background-color: #ecfdf5 !important; color: #059669 !important; border: 1px solid #a7f3d0 !important; }
        .status-Cancelled { background-color: #fef2f2 !important; color: #b91c1c !important; border: 1px solid #fca5a5 !important; }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .product-card:hover { transform: translateY(-5px); }

        #toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 9999;
            padding: 1rem 1.5rem;
            border-radius: 1rem;
            font-weight: 700;
            font-size: 0.875rem;
            opacity: 0;
            transform: translateY(1rem);
            transition: all 0.3s ease;
            pointer-events: none;
        }
        #toast.show { opacity: 1; transform: translateY(0); }
        #toast.success { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
        #toast.error   { background: #fef2f2; color: #b91c1c; border: 1px solid #fca5a5; }
    </style>
</head>
<body class="bg-slate-50 font-sans text-slate-900">
    <%- include('partials/header') %>

    <div id="toast"></div>

    <div class="min-h-screen p-4 md:p-8">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
                <div>
                    <h1 class="text-4xl font-black tracking-tighter text-slate-800 uppercase">Command Center</h1>
                    <p class="text-slate-500 font-medium">Manage your inventory and track live customer orders.</p>
                </div>
                <div class="flex gap-3 w-full md:w-auto">
                    <a href="/admin/add-product" class="flex-1 md:flex-none flex items-center justify-center gap-2 bg-slate-900 text-white px-8 py-4 rounded-2xl font-bold hover:bg-slate-800 transition-all shadow-xl active:scale-95">
                        <span class="text-xl">+</span> Add Product
                    </a>
                </div>
            </div>

            <div class="flex p-1 bg-slate-200 rounded-2xl w-full md:w-fit mb-8 shadow-inner overflow-x-auto no-scrollbar">
                <button onclick="switchTab('orders')" id="btn-orders" class="px-6 md:px-8 py-3 rounded-xl font-bold transition-all whitespace-nowrap">
                    Live Orders
                </button>
                <button onclick="switchTab('products')" id="btn-products" class="px-6 md:px-8 py-3 rounded-xl font-bold transition-all whitespace-nowrap">
                    Menu & Stock
                </button>
            </div>

            <div id="orders-section" class="tab-content">
                <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
                    <div class="bg-white rounded-[2rem] shadow-sm border border-slate-200 overflow-hidden overflow-x-auto mb-6">
                        <table class="w-full text-left border-collapse">
                            <thead class="bg-slate-50 border-b border-slate-100 uppercase text-[10px] tracking-widest font-black text-slate-400">
                                <tr>
                                    <th class="p-6">Customer Details</th>
                                    <th class="p-6">Items Ordered</th>
                                    <th class="p-6">Total Amount</th>
                                    <th class="p-6 text-right">Update Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-50">
                                <% orders.forEach(order => { %>
                                <tr class="hover:bg-slate-50/50 transition-colors">
                                    <td class="p-6">
                                        <div class="font-bold text-slate-800 text-base"><%= order.user ? order.user.username : 'Guest User' %></div>
                                        <div class="text-xs text-slate-500 font-medium mt-1"><%= order.user ? order.user.phone : 'No Phone' %></div>
                                    </td>
                                    <td class="p-6">
                                        <div class="flex flex-col gap-1.5">
                                            <% order.items.forEach(item => { %>
                                                <div class="flex items-center gap-2">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-300"></span>
                                                    <span class="text-sm font-bold text-slate-700">
                                                        <%= item.productId ? item.productId.name : 'Unknown Item' %> ×<%= item.quantity %>
                                                    </span>
                                                </div>
                                            <% }) %>
                                        </div>
                                    </td>
                                    <td class="p-6">
                                        <div class="font-black text-slate-900 text-lg">₹<%= order.totalAmount %></div>
                                    </td>
                                    <td class="p-6 text-right">
                                        <select onchange="updateOrderStatus('<%= order._id %>', this.value, this)"
                                            class="status-select font-bold text-xs rounded-xl px-4 py-3 outline-none cursor-pointer border status-<%= order.status %>">
                                            <% ['Pending','Preparing','Ready','Delivered','Cancelled'].forEach(s => { %>
                                                <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
                                            <% }) %>
                                        </select>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="bg-white p-20 rounded-[3rem] text-center border border-dashed border-slate-200">
                        <p class="text-slate-400 font-bold">No active orders right now.</p>
                    </div>
                <% } %>
            </div>

            <div id="products-section" class="tab-content hidden">
                <div class="mb-8 relative w-full md:w-96">
                    <input type="text" id="productSearch" onkeyup="filterProducts()" placeholder="Search menu..."
                           class="w-full bg-white border border-slate-200 rounded-2xl px-12 py-4 text-sm outline-none shadow-sm">
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="productGrid">
                    <% products.forEach(product => { %>
                    <div class="product-card bg-white p-4 rounded-[2.5rem] shadow-sm border border-slate-100">
                        <div class="relative overflow-hidden rounded-[2rem] mb-4 aspect-square bg-slate-100">
                            <img src="/images/<%= product.image %>" class="w-full h-full object-cover">
                            <div class="absolute top-4 left-4">
                                <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase <%= product.stock > 0 ? 'bg-emerald-500 text-white' : 'bg-red-500 text-white' %>">
                                    <%= product.stock > 0 ? 'In Stock' : 'Sold Out' %>
                                </span>
                            </div>
                        </div>
                        <h3 class="font-black text-lg text-slate-800 truncate product-name"><%= product.name %></h3>
                        <p class="text-slate-900 font-black mb-4">₹<%= product.price %></p>
                        <div class="flex items-center gap-2 mb-4 bg-slate-50 p-1.5 rounded-2xl">
                            <input type="number" id="input-stock-<%= product._id %>" value="<%= product.stock %>"
                                   class="w-full bg-transparent px-3 py-1 text-sm font-black outline-none" min="0">
                            <button onclick="updateStock('<%= product._id %>')"
                                    class="bg-slate-900 text-white px-4 py-2 rounded-xl font-bold text-xs">Update</button>
                        </div>
                        <a href="/admin/delete-product/<%= product._id %>" class="text-red-400 text-[10px] font-black uppercase block text-center">Delete</a>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script>
        function switchTab(tab) {
            const sections = {
                orders: document.getElementById('orders-section'),
                products: document.getElementById('products-section')
            };
            const buttons = {
                orders: document.getElementById('btn-orders'),
                products: document.getElementById('btn-products')
            };

            // Toggle visibility
            if (tab === 'orders') {
                sections.orders.classList.remove('hidden');
                sections.products.classList.add('hidden');
                
                buttons.orders.classList.add('bg-white', 'shadow-sm', 'text-slate-900');
                buttons.products.classList.remove('bg-white', 'shadow-sm', 'text-slate-900');
                buttons.products.classList.add('text-slate-500');
            } else {
                sections.products.classList.remove('hidden');
                sections.orders.classList.add('hidden');
                
                buttons.products.classList.add('bg-white', 'shadow-sm', 'text-slate-900');
                buttons.orders.classList.remove('bg-white', 'shadow-sm', 'text-slate-900');
                buttons.orders.classList.add('text-slate-500');
            }
            localStorage.setItem('adminActiveTab', tab);
        }

        document.addEventListener('DOMContentLoaded', () => {
            const savedTab = localStorage.getItem('adminActiveTab') || 'orders';
            switchTab(savedTab);
        });

        async function updateStock(productId) {
            const stock = document.getElementById(`input-stock-${productId}`).value;
            try {
                const res = await fetch('/admin/products/update-stock', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, stock })
                });
                const data = await res.json();
                if (data.success) alert('Stock updated!');
            } catch (err) { console.error(err); }
        }

        async function updateOrderStatus(orderId, status, el) {
            try {
                await fetch('/admin/orders/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId, status })
                });
                el.className = `status-select font-bold text-xs rounded-xl px-4 py-3 outline-none border status-${status}`;
            } catch (err) { console.error(err); }
        }

        function filterProducts() {
            const val = document.getElementById('productSearch').value.toLowerCase();
            document.querySelectorAll('.product-card').forEach(card => {
                const name = card.querySelector('.product-name').innerText.toLowerCase();
                card.style.display = name.includes(val) ? '' : 'none';
            });
        }
    </script>
</body>
</html>