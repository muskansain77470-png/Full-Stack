<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Resend OTP | FullStack Café</title>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen p-6">

    <div class="bg-white p-10 rounded-[2.5rem] shadow-xl border border-slate-100 max-w-md w-full text-center">
        <div class="mb-6 inline-flex items-center justify-center w-16 h-16 bg-slate-900 text-white rounded-2xl text-2xl font-black">
            📩
        </div>

        <h1 class="text-3xl font-black tracking-tighter text-slate-800 uppercase mb-2">Resend Code</h1>
        <p class="text-slate-500 mb-8 text-sm">Lost your code? Enter your email address below and we'll send you a fresh 6-digit OTP.</p>
        
        <div id="responseMessage" class="hidden mb-4 p-3 rounded-xl text-[10px] font-bold uppercase tracking-tight"></div>

        <form id="resendForm" class="space-y-6">
            <div class="text-left">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-2 tracking-widest px-2">Email Address</label>
                <input type="email" id="email" name="email" placeholder="name@email.com" required
                    class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-6 py-4 outline-none focus:ring-4 focus:ring-slate-900/5 focus:border-slate-900 transition-all">
            </div>

            <input type="hidden" id="type" name="type" value="signup">

            <button type="submit" id="submitBtn" class="w-full bg-slate-900 text-white py-5 rounded-2xl font-bold hover:bg-slate-800 transition-all shadow-xl active:scale-95">
                <span id="btnText">Send New OTP</span>
            </button>
        </form>

        <div class="mt-8 pt-6 border-t border-slate-50">
            <a href="/login" class="text-xs font-black text-slate-400 uppercase tracking-widest hover:text-slate-900 transition-colors">
                Back to Login
            </a>
        </div>
    </div>

    <script>
        const resendForm = document.getElementById('resendForm');
        const submitBtn = document.getElementById('submitBtn');
        const btnText = document.getElementById('btnText');
        const msgDiv = document.getElementById('responseMessage');

        resendForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            // 1. UI Loading State
            submitBtn.disabled = true;
            btnText.innerText = "Sending... ☕";
            submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
            msgDiv.classList.add('hidden');

            const payload = {
                email: document.getElementById('email').value,
                type: document.getElementById('type').value
            };

            try {
                // 2. Fetch Request to authController.postResendOTP
                const response = await fetch('/resend-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                // If the controller renders the verify-otp page upon success
                const result = await response.text();
                
                // 3. Handle result
                // We overwrite the document so the user sees the verify-otp page
                // with the fresh success message.
                document.open();
                document.write(result);
                document.close();

            } catch (err) {
                console.error("Resend Error:", err);
                msgDiv.innerText = "Network Error. Try again later.";
                msgDiv.className = "mb-4 p-3 rounded-xl bg-red-50 text-red-600 text-[10px] font-bold uppercase block";
                
                submitBtn.disabled = false;
                btnText.innerText = "Send New OTP";
                submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            }
        });
    </script>
</body>
</html>