<!DOCTYPE html>
<html>
<head>
<title>Full Stack Cafe</title>
<style>
body{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(to right,#ffecd2,#fcb69f);
    font-family:Arial;
}
.card{
    background:white;
    padding:40px;
    border-radius:10px;
    text-align:center;
    box-shadow:0 0 10px rgba(0,0,0,0.2);
}
button{
    padding:10px 20px;
    margin:10px;
    border:none;
    background:#3498db;
    color:white;
    border-radius:5px;
    cursor:pointer;
}
a{
    text-decoration:none;
}
</style>
</head>
<body>

<div class="card">
    <h1>☕ Full Stack Cafe</h1>
    <p>Order snacks & drinks easily</p>

    <a href="/login"><button>Login</button></a>
    <a href="/products"><button>View Products</button></a>
</div>

</body>
</html>